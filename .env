# CosyVoice Docker Configuration

# Service port (check availability before setting)
PORT=8188

# Host ModelScope cache directory.
# If you ran `modelscope download` inside WSL, this is usually correct.
# If you ran it from Windows PowerShell, use /mnt/c/Users/<you>/.cache/modelscope.
MODELSCOPE_CACHE=/mnt/d/Docker/modelscope

# Optional explicit paths inside the container. Leave empty to auto-detect under MODELSCOPE_CACHE.
MODEL_DIR=
ASR_MODEL_DIR=

# GPU settings (auto-selected by start.sh)
NVIDIA_VISIBLE_DEVICES=0

# GPU idle timeout in seconds (release GPU memory after idle)
GPU_IDLE_TIMEOUT=600
